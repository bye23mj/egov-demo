OPTIONS (DIRECT=FALSE, ERRORS=1000, ROWS=2000)
LOAD DATA
CHARACTERSET AL32UTF8
INFILE 'vsl_bsc.dat'
BADFILE 'vsl_bsc.bad'
DISCARDFILE 'vsl_bsc.dsc'
INTO TABLE TB_VSL_BSC
APPEND
FIELDS TERMINATED BY X'1F'
TRAILING NULLCOLS
(
  VSL_BSC_ID SEQUENCE(1,1),
  DIV_NM CHAR(4000) NULLIF DIV_NM=BLANKS,
  VSL_NO CHAR(4000) NULLIF VSL_NO=BLANKS,
  VSL_NM CHAR(4000) NULLIF VSL_NM=BLANKS,
  CMPTNC_BROF_NM CHAR(4000) NULLIF CMPTNC_BROF_NM=BLANKS,
