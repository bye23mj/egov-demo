{
  "name": "sdd-tasks",
  "displayName": "SDD Tasks (작업 분해)",
  "description": "설계 문서를 기반으로 구현 작업을 분해하고 tasks.md를 생성합니다",
  "version": "1.0.0",
  "author": "Claude Code",
  "category": "sdd",
  "keywords": ["sdd", "tasks", "breakdown", "workplan"],

  "parameters": {
    "run_id": {
      "type": "string",
      "description": "실행 ID 또는 Workspace 경로",
      "required": true,
      "examples": ["/tmp/sdd-workspaces/REQ-001"]
    }
  },

  "validation": {
    "run_id": {
      "minLength": 1,
      "message": "Run ID 또는 경로를 입력해주세요"
    }
  },

  "outputs": [
    "tasks.md (Story별 Sub-task 분해)"
  ],

  "taskStructure": {
    "unit": "Story",
    "subunit": "Sub-task (T001, T002, ...)",
    "example": "Story 1: 사용자 목록 조회 → T001~T009 (9개 Sub-task)"
  },

  "relatedSkills": ["sdd-plan"],

  "prerequisites": [
    {
      "skill": "sdd-plan",
      "reason": "Plan 완료 후 Tasks를 실행해야 합니다"
    }
  ],

  "documentation": {
    "guide": "./README.md"
  }
}
